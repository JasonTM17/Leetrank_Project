{
  "name": "leetrank",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down",
    "docker:logs": "docker compose logs -f",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "seed:extra": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-extra.ts",
    "seed:bigdata": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-bigdata.ts",
    "seed:bulk": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-bulk.ts",
    "seed:topics": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-topics.ts",
    "seed:study-plans": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-study-plans.ts",
    "seed:users": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-users-submissions.ts",
    "seed:1k": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-bulk.ts 1000 1000",
    "seed:stress": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-bulk.ts 10000 1000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install --with-deps",
    "load:smoke": "node scripts/load-test.mjs --scenario smoke",
    "load:stress": "node scripts/load-test.mjs --scenario stress",
    "load:contest": "node scripts/load-test.mjs --scenario contest-storm",
    "openapi:lint": "redocly lint apps/api/openapi.yaml services/auth-go/openapi.yaml docs/openapi.yaml",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "monaco-vim": "^0.4.4",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\",\"types\":[\"node\"]} prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2",
    "autocannon": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^6",
    "vitest": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  }
}
