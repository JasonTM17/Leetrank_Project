{
	# Global options — keep timeouts generous so judge submissions
	# (which can run up to RUNNER_TIMEOUT seconds) aren't cut off.
	servers {
		timeouts {
			read_body 30s
			read_header 10s
			write 60s
			idle 5m
		}
	}
	email {$ACME_EMAIL}
}

# Production virtual host. ACME (Let's Encrypt) certs are auto-issued
# and renewed via TLS-ALPN as long as port 443 is reachable.
{$PUBLIC_HOSTNAME:localhost} {
	encode zstd gzip

	# Standard security headers — set once in the proxy so app code
	# doesn't have to think about them.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# CSP: 'unsafe-inline' is required because Next.js 16 injects inline
		# <script> tags for hydration and route prefetching. 'unsafe-eval' is
		# required by Monaco Editor (code editor on the problem page). Both are
		# trade-offs accepted for this stack; tighten once Next.js ships nonce
		# support and Monaco drops eval.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		# Don't leak server identity.
		-Server
	}

	# Public health check — bypasses the app for liveness probes.
	handle /healthz {
		respond "ok" 200
	}

	# Coarse rate limit on auth + write endpoints. Per-IP buckets are
	# enforced inside the app too; this is a cheap first line of defense.
	@auth path /api/auth/* /api/admin/*
	rate_limit @auth {
		zone auth_zone {
			key {remote_host}
			events 30
			window 1m
		}
	}

	# Phase 3.1 destination: auth service handles all /api/v1/auth/* traffic.
	# Routes are 501 stubs until Phase 3.1.5 completes the migration from apps/web.
	# Add this block BEFORE the generic /api/v1/* reverse_proxy so auth paths
	# are matched first and never fall through to apps/api.
	handle_path /api/v1/auth/* {
		reverse_proxy auth:4001
	}

	# Ported API routes live under /api/v1/* and are served by apps/api.
	# When a route is ported from apps/web to apps/api, expose it here under
	# /api/v1/<route> and update the FE caller URL at the same cutover.
	# Routes still on apps/web continue to be served by the catch-all below.
	handle_path /api/v1/* {
		reverse_proxy api:4000
	}

	# Everything else proxied to Next.js. trusted_proxies tells the app
	# the X-Forwarded-* headers are legitimate.
	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		health_uri /api/health
		health_interval 30s
		health_timeout 5s
	}
}
