# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# compiled binaries
judge-service/judge-service

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
!.env.example
!.env.production.example

# database
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# judge temp files
judge-service/tmp/
judge-service/submissions/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# internal tooling
.omc/
.claude/worktrees/
DOCUMENTATION_MASTER.md
/scripts/*
# Project artifacts under /scripts/ that ARE tracked
!/scripts/load-test.mjs
!/scripts/load-test-fixtures.mjs

# private notes — never commit personal plans, drafts, or scratch docs
PLAN*.md
plan*.md
NOTES*.md
notes*.md
TODO*.md
todo*.md
ROADMAP*.md
roadmap*.md
DRAFT*.md
draft*.md
*.private.md
*.local.md
.claude-private/
.private/

# author-only rules — internal lessons file, not for the public repo
RULES.md

# pnpm is the workspace package manager — no npm lockfile in the tree
package-lock.json
