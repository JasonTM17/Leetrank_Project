generator client {
  provider      = "prisma-client-js"
  // Alpine images use musl + OpenSSL 3.x. Without this target the
  // generated client only ships a glibc engine and crashes at runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      String   @default("user")
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions       Submission[]
  contestEntries    ContestEntry[]
  discussions       Discussion[]
  discussionComments DiscussionComment[]
  discussionVotes   DiscussionVote[]
  bookmarks         Bookmark[]
  chatMessages      ChatMessage[]
  dailyChallengeStreak DailyChallengeStreak?

  @@index([role])
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  // LeetCode-style taxonomy: "topic" (algorithm/data-structure), "company"
  // (interview source), "skill" (language/runtime tag). Default keeps every
  // pre-existing seeded row classified as a topic without a backfill script.
  category String    @default("topic")
  problems ProblemTag[]

  @@index([category])
}

model Problem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  difficulty  String
  hints       String?
  editorial   String?
  constraints String?
  starterCode String?
  order       Int      @default(0)
  // 0..1 share of accepted submissions, refreshed by
  // src/lib/acceptance-rate.ts. Null until the first refresh runs.
  acceptanceRate Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        ProblemTag[]
  testCases   TestCase[]
  submissions Submission[]
  contestProblems ContestProblem[]
  discussions Discussion[]
  bookmarks   Bookmark[]
  dailyChallenges DailyChallenge[]

  @@index([difficulty, order])
  @@index([order])
  @@index([acceptanceRate])
}

model ProblemTag {
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([problemId, tagId])
  @@index([tagId])
}

model TestCase {
  id        String  @id @default(cuid())
  problemId String
  input     String
  expected  String
  isHidden  Boolean @default(false)
  order     Int     @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  language  String
  code      String
  status    String
  runtime   Int?
  memory    Int?
  output    String?
  error     String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, problemId, status])
  @@index([problemId, status])
  @@index([status, createdAt])
}

model Contest {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())

  problems ContestProblem[]
  entries  ContestEntry[]

  @@index([status, startTime])
  @@index([startTime])
}

model ContestProblem {
  contestId String
  problemId String
  order     Int    @default(0)
  points    Int    @default(100)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([contestId, problemId])
  @@index([problemId])
}

model ContestEntry {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  score     Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, score(sort: Desc)])
}

model Discussion {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  title     String
  body      String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem  Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments DiscussionComment[]
  votes    DiscussionVote[]

  @@index([problemId, createdAt(sort: Desc)])
  @@index([userId, createdAt])
  @@index([problemId, upvotes(sort: Desc)])
}

model DiscussionComment {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  parentId     String?
  body         String
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     DiscussionComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    DiscussionComment[] @relation("CommentReplies")

  @@index([discussionId, createdAt])
  @@index([parentId])
}

model DiscussionVote {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  value        Int      // -1 (downvote) or +1 (upvote)
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@index([discussionId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId, createdAt(sort: Desc)])
}

model ChatMessage {
  id         String   @id @default(cuid())
  userId     String
  problemId  String?
  contestId  String?
  role       String   // "user" | "assistant" | "system"
  content    String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
  @@index([contestId, createdAt])
}

// Daily challenge: one problem chosen per UTC date by the cron picker.
// `date` is the UTC midnight of the challenge day; uniqueness guarantees
// idempotency when the picker is re-run.
model DailyChallenge {
  id              String   @id @default(cuid())
  problemId       String
  date            DateTime @unique
  createdAt       DateTime @default(now())
  completionCount Int      @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([date(sort: Desc)])
}

// Per-user daily-challenge streak counter. `lastSolvedDate` stores the UTC
// midnight of the most recent solved challenge so streak math is timezone-
// independent.
model DailyChallengeStreak {
  userId         String   @id @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastSolvedDate DateTime?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
