generator client {
  provider      = "prisma-client-js"
  // Alpine images use musl + OpenSSL 3.x. Without this target the
  // generated client only ships a glibc engine and crashes at runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      String   @default("user")
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Rating fields per ADR 0021 (Glicko-2 mapped to a 1500-centred scale).
  // `rating` and `maxRating` are integers for friendly display. RD and
  // volatility are stored alongside so the engine can update incrementally
  // contest-by-contest and the inactivity cron can inflate RD over time.
  rating          Int   @default(1500)
  maxRating       Int   @default(1500)
  ratingDeviation Int   @default(350)
  ratingVolatility Float @default(0.06)

  submissions       Submission[]
  contestEntries    ContestEntry[]
  discussions       Discussion[]
  discussionComments DiscussionComment[]
  discussionVotes   DiscussionVote[]
  bookmarks         Bookmark[]
  chatMessages      ChatMessage[]
  ratingChanges     RatingChange[]
  dailyChallengeStreak DailyChallengeStreak?
  achievements      UserAchievement[]
  studyPlans        UserStudyPlan[]

  @@index([role])
  @@index([rating(sort: Desc)])
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  // LeetCode-style taxonomy: "topic" (algorithm/data-structure), "company"
  // (interview source), "skill" (language/runtime tag). Default keeps every
  // pre-existing seeded row classified as a topic without a backfill script.
  category String    @default("topic")
  problems ProblemTag[]

  @@index([category])
}

model Problem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  difficulty  String
  hints       String?
  editorial   String?
  constraints String?
  starterCode String?
  order       Int      @default(0)
  // 0..1 share of accepted submissions, refreshed by
  // src/lib/acceptance-rate.ts. Null until the first refresh runs.
  acceptanceRate Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        ProblemTag[]
  testCases   TestCase[]
  submissions Submission[]
  contestProblems ContestProblem[]
  discussions Discussion[]
  bookmarks   Bookmark[]
  dailyChallenges DailyChallenge[]
  studyPlans  StudyPlanProblem[]

  @@index([difficulty, order])
  @@index([order])
  @@index([acceptanceRate])
}

model ProblemTag {
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([problemId, tagId])
  @@index([tagId])
}

model TestCase {
  id        String  @id @default(cuid())
  problemId String
  input     String
  expected  String
  isHidden  Boolean @default(false)
  order     Int     @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  language  String
  code      String
  status    String
  runtime   Int?
  memory    Int?
  output    String?
  error     String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  events  SubmissionEvent[]

  @@index([userId, createdAt])
  @@index([userId, problemId, status])
  @@index([problemId, status])
  @@index([status, createdAt])
}

// LeetCode-style code playback. One row per recorded editor event captured
// during a coding session and flushed to the backend on submit. `ts` is a
// millisecond offset from the session start so playback math is timezone-
// and clock-skew independent. `payload` holds the event-specific shape:
//   - keystroke: { range, text, rangeLength }
//   - paste:     { range, text, rangeLength }
//   - select:    { selection: { startLineNumber, startColumn, endLineNumber, endColumn } }
//   - snapshot:  { code }
// Events are append-only; deletion cascades with the parent submission.
model SubmissionEvent {
  id           String   @id @default(cuid())
  submissionId String
  type         String
  payload      Json
  ts           Int
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, ts])
}

model Contest {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("upcoming")
  // Codeforces-style division per ADR 0021. Optional so legacy contests
  // remain "open"; new contests SHOULD set "div1" | "div2" | "div3".
  // Eligibility ranges are enforced at the API layer, not the DB.
  division    String?
  createdAt   DateTime @default(now())

  problems       ContestProblem[]
  entries        ContestEntry[]
  ratingChanges  RatingChange[]

  @@index([status, startTime])
  @@index([startTime])
  @@index([division, startTime])
}

model ContestProblem {
  contestId String
  problemId String
  order     Int    @default(0)
  points    Int    @default(100)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([contestId, problemId])
  @@index([problemId])
}

model ContestEntry {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  score     Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, score(sort: Desc)])
}

model Discussion {
  id        String   @id @default(cuid())
  problemId String
  userId    String
  title     String
  body      String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem  Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments DiscussionComment[]
  votes    DiscussionVote[]

  @@index([problemId, createdAt(sort: Desc)])
  @@index([userId, createdAt])
  @@index([problemId, upvotes(sort: Desc)])
}

model DiscussionComment {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  parentId     String?
  body         String
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     DiscussionComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    DiscussionComment[] @relation("CommentReplies")

  @@index([discussionId, createdAt])
  @@index([parentId])
}

model DiscussionVote {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  value        Int      // -1 (downvote) or +1 (upvote)
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@index([discussionId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId, createdAt(sort: Desc)])
}

model ChatMessage {
  id         String   @id @default(cuid())
  userId     String
  problemId  String?
  contestId  String?
  role       String   // "user" | "assistant" | "system"
  content    String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
  @@index([contestId, createdAt])
}

// Daily challenge: one problem chosen per UTC date by the cron picker.
// `date` is the UTC midnight of the challenge day; uniqueness guarantees
// idempotency when the picker is re-run.
model DailyChallenge {
  id              String   @id @default(cuid())
  problemId       String
  date            DateTime @unique
  createdAt       DateTime @default(now())
  completionCount Int      @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([date(sort: Desc)])
}

// Per-user daily-challenge streak counter. `lastSolvedDate` stores the UTC
// midnight of the most recent solved challenge so streak math is timezone-
// independent.
model DailyChallengeStreak {
  userId         String   @id @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastSolvedDate DateTime?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Per-contest rating delta snapshot per ADR 0021. One row per (user, contest)
// recompute. Stores both pre and post values so the user-facing rating chart
// renders without recomputing Glicko-2 history. `rank` mirrors the final
// contest standing at the moment ratings were finalised.
model RatingChange {
  id            String   @id @default(cuid())
  userId        String
  contestId     String
  beforeRating  Int
  afterRating   Int
  delta         Int
  rank          Int
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([contestId])
}

// Gamification: HackerRank-parity achievement catalog. Each row is a
// publicly-displayable badge with a machine-readable criteria spec consumed
// by `src/lib/achievements.ts`. `criteriaJson` stores the type + threshold
// (e.g. `{ "type": "problemsSolved", "threshold": 100 }`) so seeded rows
// can be tweaked without code changes. Hidden achievements (`isHidden`) are
// only revealed once earned.
model Achievement {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  icon         String
  category     String
  points       Int      @default(0)
  criteriaJson Json
  isHidden     Boolean  @default(false)
  createdAt    DateTime @default(now())

  users UserAchievement[]

  @@index([category])
}

// Per-user earned achievement record. `progress` is an optional integer that
// lets the engine show "37 / 50" toward incremental badges before they fire;
// once the threshold is reached the row also marks `earnedAt`. Composite key
// guarantees idempotent re-evaluation.
model UserAchievement {
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  progress      Int      @default(0)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@index([userId, earnedAt(sort: Desc)])
  @@index([achievementId])
}

// LeetCode-style curated study plan: an ordered set of problems grouped into
// daily lessons. `slug` is URL-safe and stable. `isOfficial` distinguishes the
// six baseline plans (Top Interview 150, Easy Collection, Dynamic Programming,
// Graph Theory, Two Pointers, Binary Search) from any user-authored plans
// added later.
model StudyPlan {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String
  difficulty      String   // "Easy" | "Medium" | "Hard" | "Mixed"
  estimatedHours  Int      @default(20)
  coverImage      String?
  isOfficial      Boolean  @default(false)
  createdAt       DateTime @default(now())

  problems StudyPlanProblem[]
  users    UserStudyPlan[]

  @@index([isOfficial, createdAt])
  @@index([difficulty])
}

// Junction model — `order` is the global position inside the plan, `dayNumber`
// groups problems into LeetCode-style daily lessons (1, 2, 3, ...). Composite
// PK on (studyPlanId, problemId) prevents a problem appearing twice in the
// same plan.
model StudyPlanProblem {
  studyPlanId String
  problemId   String
  order       Int
  dayNumber   Int

  studyPlan StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  problem   Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([studyPlanId, problemId])
  @@index([studyPlanId, order])
  @@index([studyPlanId, dayNumber])
  @@index([problemId])
}

// Per-user enrollment record. Idempotent start = upsert on the composite PK.
// `completedAt` flips when every problem in the plan has at least one accepted
// submission from the user; `lastActivityAt` is touched whenever the user
// solves a problem in the plan, so dashboards can sort by recency.
model UserStudyPlan {
  userId         String
  studyPlanId    String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  lastActivityAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlan StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@id([userId, studyPlanId])
  @@index([userId, lastActivityAt(sort: Desc)])
  @@index([studyPlanId])
}
