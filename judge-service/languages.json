{
  "$schema": "./languages.schema.json",
  "$comment": "Single source of truth for languages supported by the judge. Adding a new language is a 4-step change: append an entry here, drop a runner under judge-service/runners/ (or just a compileCmd/runCmd entry for registry-driven languages), expose it in the UI dropdown via src/lib/languages.ts, install the toolchain in judge-service/Dockerfile. Compiled languages set compileCmd; interpreted ones set runCmd directly. Placeholders {src}, {bin}, {workdir} are expanded at execution time. Wrapper-runner languages (python/javascript/ruby) keep dedicated paths in main.go because their wrappers apply per-process setrlimit guards.",
  "languages": [
    {
      "id": "python",
      "label": "Python 3",
      "extension": ".py",
      "monacoLanguage": "python",
      "kind": "interpreted",
      "runCmd": ["python3", "{src}"],
      "category": "scripting"
    },
    {
      "id": "javascript",
      "label": "JavaScript (Node)",
      "extension": ".js",
      "monacoLanguage": "javascript",
      "kind": "interpreted",
      "runCmd": ["node", "{src}"],
      "category": "scripting"
    },
    {
      "id": "typescript",
      "label": "TypeScript",
      "extension": ".ts",
      "monacoLanguage": "typescript",
      "kind": "interpreted",
      "runCmd": ["tsx", "{src}"],
      "category": "scripting"
    },
    {
      "id": "ruby",
      "label": "Ruby",
      "extension": ".rb",
      "monacoLanguage": "ruby",
      "kind": "interpreted",
      "runCmd": ["ruby", "{src}"],
      "category": "scripting"
    },
    {
      "id": "php",
      "label": "PHP",
      "extension": ".php",
      "monacoLanguage": "php",
      "kind": "interpreted",
      "runCmd": ["php", "{src}"],
      "category": "scripting"
    },
    {
      "id": "bash",
      "label": "Bash",
      "extension": ".sh",
      "monacoLanguage": "shell",
      "kind": "interpreted",
      "runCmd": ["bash", "{src}"],
      "category": "scripting"
    },
    {
      "id": "lua",
      "label": "Lua",
      "extension": ".lua",
      "monacoLanguage": "lua",
      "kind": "interpreted",
      "runCmd": ["lua5.4", "{src}"],
      "category": "scripting"
    },
    {
      "id": "perl",
      "label": "Perl",
      "extension": ".pl",
      "monacoLanguage": "perl",
      "kind": "interpreted",
      "runCmd": ["perl", "{src}"],
      "category": "scripting"
    },
    {
      "id": "elixir",
      "label": "Elixir",
      "extension": ".ex",
      "monacoLanguage": "elixir",
      "kind": "interpreted",
      "runCmd": ["elixir", "{src}"],
      "category": "scripting"
    },
    {
      "id": "go",
      "label": "Go",
      "extension": ".go",
      "monacoLanguage": "go",
      "kind": "compiled",
      "compileCmd": ["go", "build", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "rust",
      "label": "Rust",
      "extension": ".rs",
      "monacoLanguage": "rust",
      "kind": "compiled",
      "compileCmd": ["rustc", "-O", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "c",
      "label": "C (gcc)",
      "extension": ".c",
      "monacoLanguage": "c",
      "kind": "compiled",
      "compileCmd": ["gcc", "-O2", "-std=c17", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "cpp",
      "label": "C++ (g++)",
      "extension": ".cpp",
      "monacoLanguage": "cpp",
      "kind": "compiled",
      "compileCmd": ["g++", "-O2", "-std=c++20", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "csharp",
      "label": "C# (Mono)",
      "extension": ".cs",
      "monacoLanguage": "csharp",
      "kind": "compiled",
      "compileCmd": ["mcs", "-out:{workdir}/main.exe", "{src}"],
      "runCmd": ["mono", "{workdir}/main.exe"],
      "category": "compiled"
    },
    {
      "id": "d",
      "label": "D (gdc)",
      "extension": ".d",
      "monacoLanguage": "d",
      "kind": "compiled",
      "compileCmd": ["gdc", "-O", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "pascal",
      "label": "Pascal (fpc)",
      "extension": ".pas",
      "monacoLanguage": "pascal",
      "kind": "compiled",
      "compileCmd": ["fpc", "-O2", "-o{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "fortran",
      "label": "Fortran (gfortran)",
      "extension": ".f90",
      "monacoLanguage": "fortran",
      "kind": "compiled",
      "compileCmd": ["gfortran", "-O2", "-o", "{bin}", "{src}"],
      "runCmd": ["{bin}"],
      "category": "compiled"
    },
    {
      "id": "java",
      "label": "Java",
      "extension": ".java",
      "monacoLanguage": "java",
      "kind": "compiled",
      "compileCmd": ["javac", "-d", "{workdir}", "{src}"],
      "runCmd": ["java", "-cp", "{workdir}", "Main"],
      "mainClass": "Main",
      "category": "jvm"
    },
    {
      "id": "kotlin",
      "label": "Kotlin",
      "extension": ".kt",
      "monacoLanguage": "kotlin",
      "kind": "compiled",
      "compileCmd": ["kotlinc", "{src}", "-include-runtime", "-d", "{workdir}/main.jar"],
      "runCmd": ["java", "-jar", "{workdir}/main.jar"],
      "category": "jvm"
    },
    {
      "id": "scala",
      "label": "Scala",
      "extension": ".scala",
      "monacoLanguage": "scala",
      "kind": "compiled",
      "compileCmd": ["scalac", "-d", "{workdir}", "{src}"],
      "runCmd": ["scala", "-cp", "{workdir}", "Main"],
      "mainClass": "Main",
      "category": "jvm"
    },
    {
      "id": "groovy",
      "label": "Groovy",
      "extension": ".groovy",
      "monacoLanguage": "groovy",
      "kind": "interpreted",
      "runCmd": ["groovy", "{src}"],
      "category": "jvm"
    },
    {
      "id": "clojure",
      "label": "Clojure",
      "extension": ".clj",
      "monacoLanguage": "clojure",
      "kind": "interpreted",
      "runCmd": ["clojure", "-M", "{src}"],
      "category": "jvm"
    },
    {
      "id": "haskell",
      "label": "Haskell",
      "extension": ".hs",
      "monacoLanguage": "haskell",
      "kind": "interpreted",
      "runCmd": ["runghc", "{src}"],
      "category": "functional"
    },
    {
      "id": "ocaml",
      "label": "OCaml",
      "extension": ".ml",
      "monacoLanguage": "ocaml",
      "kind": "interpreted",
      "runCmd": ["ocaml", "{src}"],
      "category": "functional"
    },
    {
      "id": "racket",
      "label": "Racket",
      "extension": ".rkt",
      "monacoLanguage": "racket",
      "kind": "interpreted",
      "runCmd": ["racket", "{src}"],
      "category": "functional"
    },
    {
      "id": "sbcl",
      "label": "Common Lisp (SBCL)",
      "extension": ".lisp",
      "monacoLanguage": "lisp",
      "kind": "interpreted",
      "runCmd": ["sbcl", "--script", "{src}"],
      "category": "functional"
    },
    {
      "id": "erlang",
      "label": "Erlang",
      "extension": ".erl",
      "monacoLanguage": "erlang",
      "kind": "interpreted",
      "runCmd": ["escript", "{src}"],
      "category": "functional"
    },
    {
      "id": "fsharp",
      "label": "F# (Mono)",
      "extension": ".fsx",
      "monacoLanguage": "fsharp",
      "kind": "interpreted",
      "runCmd": ["fsharpi", "--exec", "{src}"],
      "category": "functional"
    },
    {
      "id": "sql",
      "label": "SQL (sqlite)",
      "extension": ".sql",
      "monacoLanguage": "sql",
      "kind": "interpreted",
      "runCmd": ["sqlite3", ":memory:", ".read {src}"],
      "category": "data"
    },
    {
      "id": "r",
      "label": "R",
      "extension": ".r",
      "monacoLanguage": "r",
      "kind": "interpreted",
      "runCmd": ["Rscript", "{src}"],
      "category": "data"
    },
    {
      "id": "tcl",
      "label": "Tcl",
      "extension": ".tcl",
      "monacoLanguage": "tcl",
      "kind": "interpreted",
      "runCmd": ["tclsh", "{src}"],
      "category": "esoteric"
    },
    {
      "id": "awk",
      "label": "AWK (gawk)",
      "extension": ".awk",
      "monacoLanguage": "plaintext",
      "kind": "interpreted",
      "runCmd": ["gawk", "-f", "{src}"],
      "category": "esoteric"
    }
  ]
}
