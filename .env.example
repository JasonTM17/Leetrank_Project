# ─── Container deployment (docker-compose.yml is the canonical path) ───
# - DATABASE_URL: Postgres connection string. The compose stack provisions
#                 postgres:16 at db:5432 — use that hostname inside containers.
#                 If you run `prisma migrate` from CI, also set DIRECT_URL.
# - REDIS_URL: Redis connection string (compose runs redis:7 at redis:6379).
# - JWT_SECRET: 32+ char secret. Required in production; the server refuses
#               to start without it. Generate with `openssl rand -hex 32`.
# - NEXT_PUBLIC_APP_URL: canonical https URL of the deployment, e.g.
#                       https://leetrank.example.com or your reverse-proxy host.
# - JUDGE_SERVICE_URL: judge service URL (defaults to http://judge:9090 inside
#                     the compose network; submission flow falls back to demo
#                     mode if unset).
# - N8N_CHATBOT_WEBHOOK_URL: optional; chat uses local fallback replies if unset.
# See docs/onboarding.md for the full setup walkthrough.
# ────────────────────────────────────────────────────────────────

# Local dev: matches docker-compose's postgres service. The Prisma schema
# uses postgres-only features (composite indexes, sort modifiers), so a
# sqlite quick-start (`file:./dev.db`) won't satisfy `prisma migrate`.
DATABASE_URL="postgresql://leetrank:leetrank-dev@localhost:5432/leetrank?schema=public"
# Generate a strong secret: `openssl rand -hex 32` (must be 16+ chars; production fails to start otherwise)
JWT_SECRET="replace-with-openssl-rand-hex-32-output-min-16-chars"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
JUDGE_SERVICE_URL="http://localhost:9090"
RUNNER_TIMEOUT="5"

# ── Code playback (LeetCode-style replay) ─────────────────────────────────────
# When "true", /api/submissions/[id]/events accepts recorded editor events
# and /api/submissions/[id]/playback returns the stream for the viewer.
# Defaults to "false" so the routes return 404 until the feature is shipped.
PLAYBACK_ENABLED="false"

# ── apps/api (standalone backend, port 4000) ──────────────────────────────────
# Same DATABASE_URL + JWT_SECRET as above; the API service consumes them too.
# API_PORT     — TCP port the Hono server binds (default 4000)
# CORS_ALLOWED_ORIGINS — comma-separated exact-match origins. EMPTY in production
#                       rejects all cross-origin requests. Dev allows any
#                       http://localhost:* / 127.0.0.1:* automatically.
API_PORT="4000"
CORS_ALLOWED_ORIGINS=""

# ── Bulk-seed sizing (prisma/seed-bulk.ts) ────────────────────────────────────
# Override via `npm run seed:bulk -- 500 200` or env. Defaults: 1000/1000.
SEED_PROBLEMS="1000"
SEED_CONTESTS="1000"

# ── n8n chatbot (RULES §15) ───────────────────────────────────────────────────
# Set N8N_CHATBOT_WEBHOOK_URL to the workflow's POST endpoint.
# Run n8n locally: docker compose -f docker-compose.yml -f infra/n8n/docker-compose.snippet.yml up n8n
N8N_CHATBOT_WEBHOOK_URL="http://localhost:5678/webhook/leetrank-chatbot"
# HMAC secret shared with n8n. Required in production; dev skips signing if empty.
# Generate with: openssl rand -hex 32  — must match the value in the n8n workflow.
N8N_HMAC_SECRET=""
N8N_USER="admin"
N8N_PASSWORD="change-me"

# Postgres / Redis are seeded by docker-compose; override only if you bring your own.
POSTGRES_USER="leetrank"
POSTGRES_PASSWORD="leetrank-dev"
POSTGRES_DB="leetrank"
REDIS_PASSWORD="leetrank-dev"

# n8n service-network host. Inside docker, the chat route uses this:
N8N_HOST="n8n"
N8N_PORT="5678"

# ── OpenTelemetry tracing (opt-in observability overlay) ──────────────────────
# Tempo runs in docker-compose.observability.yml. Point any service's OTel SDK
# at the OTLP HTTP endpoint below; use http://tempo:4317 if the SDK uses gRPC.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable tracing entirely.
OTEL_EXPORTER_OTLP_ENDPOINT="http://tempo:4318"
OTEL_TRACES_EXPORTER="otlp"
OTEL_SERVICE_NAME="leetrank-web"
