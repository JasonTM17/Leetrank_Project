{
  "name": "@leetrank/api",
  "version": "0.1.0",
  "private": true,
  "description": "LeetRank backend API service. Standalone HTTP server consumed by the web app and external clients.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@prisma/client": "^5.22.0",
    "hono": "^4.12.23",
    "jose": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prisma": "^5.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
