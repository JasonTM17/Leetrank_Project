# Production environment template — copy to `.env.production` and fill values.
# All secrets must be set; the stack refuses to boot otherwise.

# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://leetrank.example.com
LOG_LEVEL=info

# ─── Database (Postgres) ────────────────────────────────────────────────────
# DATABASE_URL points the app at the Postgres container. POSTGRES_* configures
# the container itself — keep them consistent.
DATABASE_URL=postgresql://leetrank:CHANGE_ME_STRONG_PASSWORD@postgres:5432/leetrank?schema=public&connection_limit=10
POSTGRES_USER=leetrank
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=leetrank

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be 16+ characters. The app fails to start otherwise.
JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32

# ─── Cache / queue (Redis) ──────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Judge service ──────────────────────────────────────────────────────────
JUDGE_SERVICE_URL=http://judge:9090
RUNNER_TIMEOUT=5
JUDGE_GLOBAL_MAX=32
JUDGE_PER_IP_MAX=4
JUDGE_QUEUE_WAIT_MS=10000

# ─── TLS / proxy (Caddy) ────────────────────────────────────────────────────
# Email is required by Let's Encrypt for cert renewal notifications.
ACME_EMAIL=ops@example.com
PUBLIC_HOSTNAME=leetrank.example.com

# ─── Observability ──────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=15d

# ─── n8n chatbot ────────────────────────────────────────────────────────────
# HMAC secret signed into outbound calls as `X-LeetRank-Signature` and verified
# inside the n8n workflow. See docs/runbooks/n8n.md.
# Generate with: openssl rand -hex 32
N8N_CHATBOT_WEBHOOK_URL=https://n8n.example.com/webhook/leetrank-chatbot
N8N_HMAC_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32
